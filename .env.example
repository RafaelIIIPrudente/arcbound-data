# Copy this file to `.env` and fill in the values.
# See README.md → "Connect Supabase" for where each value comes from.

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the site. In production set this to your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: shown in metadata. Usually your app version or a git sha.
NEXT_PUBLIC_SITE_VERSION=

# ── Logging ──────────────────────────────────────────────────────────────────
# One of: NONE | ERROR | WARN | DEBUG | ALL
NEXT_PUBLIC_LOG_LEVEL=ALL

# ── Auth ─────────────────────────────────────────────────────────────────────
# Only SUPABASE is wired in this template.
NEXT_PUBLIC_AUTH_STRATEGY=SUPABASE

# ── Supabase ─────────────────────────────────────────────────────────────────
# Hosted: Supabase project → Settings → Data API (URL) and API Keys (anon).
# Local:  run `supabase start` and copy the printed API URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
